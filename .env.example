# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Supabase (auth + DB) ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── AI — Gemini (Phase 2+) ────────────────────────────────────────────────────
# Primary AI provider. Get a free key at https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key

# ── AI — Legacy (keep as fallback during migration) ───────────────────────────
TOGETHER_API_KEY=your-together-api-key
GROQ_API_KEY=your-groq-api-key

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-password
RESEND_API_KEY=your-resend-key

# ── Firebase Admin (Phase 3 — FCM push notifications) ────────────────────────
# Option A: paste the entire service-account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option B: individual fields (better for CI/CD secret managers)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Telegram (optional) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-token
